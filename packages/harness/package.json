{
  "name": "@nextstage-brasil/harness",
  "version": "0.16.0",
  "description": "Interactive CLI to install NextStage skills and scaffold SDD project layout",
  "type": "module",
  "bin": {
    "harness": "bin/cli.js"
  },
  "files": [
    "bin",
    "src",
    "templates",
    "scripts",
    "docs"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test": "node bin/cli.js list && node bin/cli.js --dry-run --yes --preset gitlab && node test/sync-smoke.mjs",
    "validate:catalog": "node scripts/validate-catalog.js"
  },
  "keywords": [
    "nextstage",
    "skills",
    "harness",
    "sdd",
    "agent-skills"
  ],
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nextstage-brasil/skills.git",
    "directory": "packages/harness"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.1"
  }
}
